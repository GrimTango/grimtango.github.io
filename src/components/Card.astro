---
import "../styles/global.css";
import { Image } from "astro:assets";

interface Props {
    bg: ImageMetadata;
    title: string;
    content: string;
    bgalt: string;
}

const { bg, title, content, bgalt } = Astro.props;
---

<div class="flex flex-col gap-8 md:flex-row">
    <Image
        class="scale-[1.01] rounded-xl object-cover transition-all duration-250 hover:scale-[1.02] md:w-[60%]"
        src={bg}
        alt={bgalt}
        loading="eager"
        decoding="sync"
    />
    <div class="flex flex-col md:w-[40%]">
        <h1>{title}</h1>
        {content}
    </div>
</div>
